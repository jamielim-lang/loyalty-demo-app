<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Offer image with badge overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/iv_offer_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#E5E7EB"
                android:contentDescription="Offer image" />

            <!-- Store logo bottom-left -->
            <TextView
                android:id="@+id/tv_store_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="10dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="coles"
                android:textSize="13sp"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:background="@color/flybuys_red" />

            <!-- Points badge bottom-right -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="10dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/bg_offer_badge"
                    android:contentDescription="Badge background" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_badge_multiplier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5x"
                        android:textSize="18sp"
                        android:textColor="@color/flybuys_blue"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POINTS"
                        android:textSize="9sp"
                        android:textColor="@color/flybuys_blue"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                </LinearLayout>

            </FrameLayout>

        </FrameLayout>

        <!-- Offer details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_offer_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Collect 5x points"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_offer_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="on every transaction in-store or online at Coles."
                android:textSize="13sp"
                android:textColor="@color/text_body"
                android:maxLines="2" />

            <!-- Expiry row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_expiry_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="Expiry clock" />

                <TextView
                    android:id="@+id/tv_expiry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Ends today"
                    android:textSize="13sp"
                    android:textColor="@color/offer_expiry_red" />

            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_hide"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Hide"
                    android:textSize="14sp"
                    android:textColor="@color/flybuys_blue"
                    android:background="@drawable/bg_button_secondary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btn_activate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Activate"
                    android:textSize="14sp"
                    android:textColor="@color/text_white"
                    android:backgroundTint="@color/flybuys_blue"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
