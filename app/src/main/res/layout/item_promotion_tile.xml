<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="4dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Circular promo image -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp">

        <ImageView
            android:id="@+id/iv_promo_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_promo_circle"
            android:contentDescription="Promotion image" />

        <!-- Store badge overlay at bottom -->
        <TextView
            android:id="@+id/tv_store_badge"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:text="Coles"
            android:textSize="10sp"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:background="@color/flybuys_red" />

    </FrameLayout>

    <!-- Promo title -->
    <TextView
        android:id="@+id/tv_promo_title"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:maxLines="2"
        android:text="European Glassware"
        android:textSize="11sp"
        android:textColor="@color/text_body" />

</LinearLayout>
